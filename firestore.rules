rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Existing trips — anyone can read, authenticated users can write
    match /UserTrips/{tripId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Price searches — Cloud Function (admin SDK) writes;
    // users can read their own searches for history chart
    match /priceSearches/{docId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow write: if false; // admin SDK bypasses rules
    }

    // User preferences — each user reads/writes only their own doc
    match /userPreferences/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Agent jobs — users can read their own jobs (onSnapshot listener)
    // Cloud Function (admin SDK) handles writes
    match /agentJobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if false; // admin SDK bypasses rules
    }

    // Itinerary cache — read-only for authenticated users
    // Cloud Function (admin SDK) handles writes
    match /itineraryCache/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // admin SDK bypasses rules
    }
  }
}